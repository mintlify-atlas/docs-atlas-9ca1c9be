    "GET /carrito (Shopping cart)",
    "GET /checkout (Checkout - protected)",
    "GET /confirmacion (Order confirmation - protected)",
    "GET /cliente (Client dashboard - role: client)",
    "GET /vendedor (Seller dashboard - role: seller/admin)",
    "GET /admin (Admin overview - role: admin)",
