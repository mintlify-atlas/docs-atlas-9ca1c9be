  "keyFeatures": [
    "Product catalog with filters, sorting, and price range",
    "Shopping cart with localStorage persistence",
    "Multi-step checkout with order confirmation",
    "Role-based access control (client, seller, admin)",
    "Client dashboard with order history, wishlist, and project calculator",
    "Seller dashboard with product management, orders, and stock alerts",
    "Admin panel with user management, inventory, analytics, and support tools",
    "Dark mode support via Tailwind CSS",
    "Animated page transitions with Framer Motion",
    "PostgreSQL database with Java backend API"
  ],
